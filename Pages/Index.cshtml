@page
@{
    Layout = null;   // remove this line if you already use _Layout.cshtml
    ViewData["Title"] = "Salon Services";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Salon Services</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

    <style>
            body {
                background-color: #f5f5f5;
            }

            .hero {
                background: url('https://images.unsplash.com/photo-1522335789203-aabd1fc54bc9') center/cover no-repeat;
                height: 220px;
                border-radius: 12px;
                color: white;
                display: flex;
                align-items: end;
                padding: 20px;
                font-size: 26px;
                font-weight: bold;
            }

            .service-card {
                background: #fff;
                border-radius: 12px;
                padding: 12px;
                margin-bottom: 12px;
                box-shadow: 0 2px 6px rgba(0,0,0,0.08);
            }

            .service-img {
                width: 90px;
                height: 90px;
                border-radius: 10px;
                object-fit: cover;
            }

            .price {
                font-weight: bold;
            }

            .cart-bar {
                position: sticky;
                bottom: 0;
                background: #fff;
                padding: 10px;
                border-top: 1px solid #ddd;
            }
    </style>
</head>
<body>

    <div class="container mt-3">

        <!-- Hero -->
        <div class="hero mb-3">
            Salon at Home
        </div>

        <h5 class="mb-3">Popular Services</h5>

        <!-- Service 1 -->
        <div class="service-card d-flex justify-content-between align-items-center">
            <div class="d-flex">
                <img src="https://images.unsplash.com/photo-1595476108010-b4d1f102b1b1" class="service-img me-3" />
                <div>
                    <div><strong>Haircut for Women</strong></div>
                    <small class="text-muted">Wash & blow dry included</small>
                    <div class="price">₹999</div>
                </div>
            </div>
            <button class="btn btn-dark btn-sm">Add</button>
        </div>

        <!-- Service 2 -->
        <div class="service-card d-flex justify-content-between align-items-center">
            <div class="d-flex">
                <img src="https://images.unsplash.com/photo-1580618672591-eb180b1a973f" class="service-img me-3" />
                <div>
                    <div><strong>Facial Cleanup</strong></div>
                    <small class="text-muted">Glowing skin treatment</small>
                    <div class="price">₹2000</div>
                </div>
            </div>
            <button class="btn btn-dark btn-sm">Add</button>
        </div>

        <!-- Service 3 -->
        <div class="service-card d-flex justify-content-between align-items-center">
            <div class="d-flex">
                <img src="https://images.unsplash.com/photo-1600948836101-f9ffda59d250" class="service-img me-3" />
                <div>
                    <div><strong>Manicure</strong></div>
                    <small class="text-muted">Hand care & polish</small>
                    <div class="price">₹599</div>
                </div>
            </div>
            <button class="btn btn-dark btn-sm">Add</button>
        </div>

    </div>

    <!-- Bottom Cart -->
    <div class="cart-bar d-flex justify-content-between align-items-center">
        <div>
            <strong>0 items</strong><br />
            <small class="text-muted">₹0 total</small>
        </div>
        <button class="btn btn-success">Proceed</button>
    </div>

</body>
</html>